# Directory where karn writes and reads all data artifacts (prints.db, chroma_db/, graph.json).
# Matches the path KarnForge resolves via utils/paths.js → resolveArsenalDbDir().
#
# Windows : C:\Users\<user>\karnData\arsenal\db
# macOS   : ~/.karnData/arsenal/db  (note: macOS uses .karnData with a dot)
#
# Override for local dev builds that should stay inside the repo:
#   KARN_DATA_DIR=./db
KARN_DATA_DIR=~/karnData/arsenal/db

# Required for install_data.py and upload_data.py
KARN_GITHUB_REPO=your-org/karn

# Encoding fix for Windows MCP pipe
PYTHONIOENCODING=utf-8
